generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Contact {
  id        Int      @id @default(autoincrement())
  company   String?
  name      String?
  email     String?
  phone     String?
  message   String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}